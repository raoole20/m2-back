<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Verify your email</title>
</head>
<body style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 24px; color: #222;">
  <h2>Hello {{name}},</h2>
  <p>Welcome to M2. Confirm your email to activate your account.</p>
  <p style="margin: 24px 0;">
    <a href="{{verifyUrl}}"
       style="background:#2563eb;color:#fff;padding:12px 20px;text-decoration:none;border-radius:6px;display:inline-block;">
      Verify email
    </a>
  </p>
  <p style="color:#666;font-size:12px;">
    Or paste this URL in your browser:<br>
    <span style="word-break:break-all;">{{verifyUrl}}</span>
  </p>
  <p style="color:#666;font-size:12px;">This link expires in {{ttlHours}} hours.</p>
  <hr style="margin:24px 0;border:none;border-top:1px solid #eee;">
  <p style="color:#999;font-size:11px;">If you did not register, ignore this email.</p>
</body>
</html>
